# Browser dev (Vite proxy — start API with `php artisan serve`):
VITE_API_URL=/api/v1/mobile
VITE_API_ROOT=

# Physical device / Capacitor build — replace with your machine LAN IP:
# VITE_API_URL=http://192.168.1.10:8000/api/v1/mobile
# VITE_API_ROOT=http://192.168.1.10:8000
# API: php artisan serve --host=0.0.0.0 --port=8000

VITE_REVERB_APP_KEY=your_app_key
VITE_REVERB_HOST=localhost
VITE_REVERB_PORT=8080
VITE_REVERB_SCHEME=http

VITE_TELEGRAM_BOT_USERNAME=your_bot_username
