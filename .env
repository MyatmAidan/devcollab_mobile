# USB dev (adb reverse tcp:8000 tcp:8000) — works with Mac firewall on
VITE_API_URL=http://127.0.0.1:8000/api/v1/mobile
VITE_API_ROOT=http://127.0.0.1:8000

# Wi-Fi alternative (requires Mac firewall to allow PHP incoming):
# VITE_API_URL=http://192.168.100.75:8000/api/v1/mobile
# VITE_API_ROOT=http://192.168.100.75:8000

VITE_REVERB_APP_KEY=local-key
VITE_REVERB_HOST=127.0.0.1
VITE_REVERB_PORT=8080
VITE_REVERB_SCHEME=http

VITE_TELEGRAM_BOT_USERNAME=devcollab_bot
